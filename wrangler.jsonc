{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "reviewbot",
  "main": "src/server.ts",
  "compatibility_date": "1999-12-31",
  "compatibility_flags": ["nodejs_compat"],
  "ai": { "binding": "AI", "remote": true },
  "assets": {
    "directory": "./public",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*", "/mcp/*"]
  },
  "durable_objects": {
    "bindings": [
      { "class_name": "ReviewAgent", "name": "ReviewAgent" },
      { "class_name": "ReviewMCP", "name": "ReviewMCP" }
    ]
  },
  "workflows": [
    {
      "name": "review-workflow",
      "binding": "REVIEW_WORKFLOW",
      "class_name": "ReviewWorkflow"
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ReviewAgent"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["ReviewMCP"]
    }
  ],
  "observability": {
    "enabled": true
  },
  "vars": {
    "AI_GATEWAY_ID": ""
  }
}
